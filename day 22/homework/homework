#.append() ფუნქცია სიის ბოლოში ამატებს ელემენტს
#.pop(index) ფუნქცია აგდებს ელემენტს მითითებული ნუმერაციით(თუ ინდექსს არ ჩავწერთ, ავტომატურად წაშლის ბოლო ელემენტს)
#.insert(index, element)  ამატებს ელემენტს მითითებულ პოზიციაზე (ინდექსზე)
def fruits():
    fruits = ['mango', 'kiwi', 'kiwano', 'lychee', 'apple']
    print(len(fruits))

def numbers():
    numbers = []
    for i in range(5):
        number=int(input('Say any number'))
        numbers.append(number)
    print(numbers)

def colors():
    colors = ["red", "green", "blue", "yellow", "purple"]
    colors.pop(4)
    print(colors)

def animals():
    animals = ["dog", "cat", "elephant", "lion"]
    animals.insert(1,'monkey')
    print(animals)
    
def school():
    students = []
    for i in range(3):
        student = input('Enter student name')
        students.append(student)
    students.insert(0,'Teacher')
    students.pop(3)
    print(students)

school()
animals()
colors()
numbers()
fruits()